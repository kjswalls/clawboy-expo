{
  "expo": {
    "name": "clawboy-expo",
    "slug": "clawboy-expo",
    "scheme": "clawboy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1219"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.clawboy-expo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1219"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "mode": "development"
        }
      ]
    ]
  }
}
