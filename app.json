{
  "expo": {
    "name": "ClawBoy",
    "slug": "clawboy",
    "scheme": "clawboy",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3574328d-7de7-44a4-b220-74d7fb28a903",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "codeSigningCertificate": "./certs/certificate.pem",
      "codeSigningMetadata": {
        "keyid": "main",
        "alg": "rsa-v1_5-sha256"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1219"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sundaysoftworks.clawboy",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "ClawBoy uses the microphone to record voice notes you send to your OpenClaw gateway.",
        "NSSpeechRecognitionUsageDescription": "ClawBoy uses on-device speech recognition to transcribe voice notes for models that don't accept audio.",
        "NSPhotoLibraryAddUsageDescription": "Save media you receive from your agents to your photo library.",
        "NSPhotoLibraryUsageDescription": "Save media you receive from your agents to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1219"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.sundaysoftworks.clawboy"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-updates",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "ClawBoy needs photo library access to attach images and videos you choose.",
          "cameraPermission": "ClawBoy uses the camera to capture photos and videos to send to your gateway."
        }
      ],
      [
        "expo-notifications",
        {
          "mode": "development"
        }
      ],
      "expo-video",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "ClawBoy uses the microphone to record voice notes you send to your OpenClaw gateway.",
          "speechRecognitionPermission": "ClawBoy uses on-device speech recognition to transcribe voice notes for models that don't accept audio."
        }
      ],
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "Save media you receive from your agents to your photo library.",
          "savePhotosPermission": "Save media you receive from your agents to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "feedbackProxyUrl": "https://clawboy-feedback-worker.sundaysoftworks.workers.dev/v1/feedback",
      "supabaseUrl": "https://esgqjzzhytxdkdwkguws.supabase.co",
      "supabaseAnonKey": "sb_publishable_W1yvyEcmd7NKDeeDhqtZ9g_EReqvBp-",
      "revenueCatApiKeyIos": "",
      "revenueCatApiKeyAndroid": "",
      "router": {},
      "eas": {
        "projectId": "3574328d-7de7-44a4-b220-74d7fb28a903"
      }
    },
    "owner": "kjswalls"
  }
}
